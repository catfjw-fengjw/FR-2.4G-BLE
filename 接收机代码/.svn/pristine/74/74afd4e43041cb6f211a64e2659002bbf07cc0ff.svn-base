uint16_t ClosePWMCntms;   			/* 关PWM */




//=========UART=======================
// UART_EN_FG		=>	1;			//UART 使能  0：失能 1：使能
// #define		UART_EN_FG		

#define		UART_EN_FG		1	 	//UART 使能  0：失能 1：使能

//PA.5脚为UART发送端口，使用软件模拟UART发送数据
UART_Out		BIT	PA.5;				//发送端口
LOG_BUFF_Size	=>	10	//10组数据

#define		AD_LOG			 (0xAD)
#define		KEY_1_SHORT_LOG	 (0xB1)
#define		KEY_2_SHORT_LOG	 (0xB2)
#define		KEY_1_LONG_LOG	 (0xB3)
#define		KEY_2_LONG_LOG	 (0xB4)
#define		RX_LOG	 		 (0xC1)
#define		LOG_Ing	 		 (0xD1)


byte	Log_Buf_Out[LOG_BUFF_Size];//定义十组需要发送的数据



//=======SPI+RF=========
SPI_CSN		=>	PA.7
SPI_CLK		=>	PA.6
SPI_DATA	=>	PA.3

.RAMADR 0X00  //地址定义为0
word gw_Point;


// uint16_t rf_adv_channel[3] = {RF_ADV_CHANNEL_37, RF_ADV_CHANNEL_38, RF_ADV_CHANNEL_39};
uint16_t rf_adv_channel[3];

uint8_t adv_idx = 0;


/*

0x30 --> 0
0x31 --> 1
0x32 --> 2
0x33 --> 3
0x34 --> 4
0x35 --> 5
0x36 --> 6
0x37 --> 7
0x38 --> 8
0x39 --> 9
0x3A --> :  待机模式

*/

#define TX_MODE         1
#define RX_MODE         0
// TRANS_MODE  =>  0 // RX_MODE//TX_MODE
#define TRANS_MODE         TX_MODE

uint8_t RF_InitFg = 0;


#if (TRANS_MODE == TX_MODE)	
	uint8_t WorkMode = 0x3A;
	uint8_t SendWorkMode = 0x3A;
	uint8_t SendCnt = 0;

#elif (TRANS_MODE == RX_MODE)
	uint8_t WorkMode = 0x00;
    byte RX_len = 0;

#endif


/* RF Register Address */
#define CFG_TOP                       (0x00)
#define EN_AA                         (0x01)
#define EN_RXADDR                     (0x02)
#define SETUP_AW                      (0x03)
#define SETUP_RETR                    (0x04)
#define RF_CH                         (0x05)
#define SETUP_RF                      (0x06)
#define STATUS                        (0x07)
#define OBSERVE_TX                    (0x08)
#define RSSI                          (0x09)
#define RX_ADDR_P0                    (0x0A)
#define RX_ADDR_P1                    (0x0B)
#define RX_ADDR_P2_TOP5               (0x0C)    /*!< */

#define BER_RESULT                    (0x0D)
#define AGC_SETTING                   (0x0E)
#define PGA_SETTING                   (0x0F)
#define TX_ADDR                       (0x10)
#define RX_PW_PX                      (0x11)
#define ANALOG_CFG0                   (0x12)
#define ANALOG_CFG1                   (0x13)
#define ANALOG_CFG2                   (0x14)
#define ANALOG_CFG3                   (0x15)
#define STATUS_FIFO                   (0x17)
#define RSSIREC                       (0x18)
#define TXPROC_CFG                    (0x19)
#define RXPROC_CFG                    (0x1A)
#define DYNPD                         (0x1C)
#define FEATURE                       (0x1D)
#define RAMP_CFG                      (0x1E)
#ifdef XC820
#define RXPROC_CFG_H                  (0x1F)
#define PREAMBLE                      (0x20)
#define GUARD                         (0x21)
#define CMD_BYTE                      (0x22)
#define PEND_RXFRM_LEN                (0x23)
#define HW_CONFIG                     (0x24)
#define PBT_CONFIG                    (0x25)
#define PBT_TIMER                     (0x26)
#define PBT_SYNC_TIME                 (0x27)
#endif
/* RF Command Code */
#define R_REG                         0x00
#define W_REG                         0x20
#define R_RX_PL_WID                   0x60
#define R_RX_PLOAD                    0x61
#define W_TX_PLOAD                    0xA0
#define W_TX_PLOAD_NOACK              0xB0
#define W_ACK_PLOAD                   0xA8
#define FLUSH_TX                      0xE1
#define FLUSH_RX                      0xE2
#define REUSE_TX_PL                   0xE3

#define CMD_NOP                       0xFF



/* STATUS Interrupt status */
#define RX_DR          (0x1 << 6)
#define TX_DS          (0x1 << 5)
#define MAX_RT         (0x1 << 4)
/* FIFO status */
#define STAT_TX_REUSE  (0x1 << 6)
#define STAT_TX_FULL   (0x1 << 5)
#define STAT_TX_EMPTY  (0x1 << 4)
#define STAT_RX_FULL   (0x1 << 1)
#define STAT_RX_EMPTY  (0x1 << 0)

#define ENAA_SET_VAL 0x41

	// ((x)[(y)>>3] |=  (1U << ((y)&7)));
	// ((x)[(y)>>3] &= ~(1U << ((y)&7)));
