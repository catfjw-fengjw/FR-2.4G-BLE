//修改按键需修改外部中断
//PC.0脚为按键输入，低电平有效
#define		KEY_1_IO	 PB.0//定义按键的脚位

bit KeyFlag_1;  			//启动按键检测
bit JugeKeyStateFlag_1;		//消抖结束-->判断按键状态
