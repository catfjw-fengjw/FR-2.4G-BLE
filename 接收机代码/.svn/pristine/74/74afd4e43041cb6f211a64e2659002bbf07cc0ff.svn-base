bit LongKeyProFlag_1;		//防止重复检测
uint16_t KeyCount1ms_1;		//按键计时
	
bit ShortKeyFlag_1;
bit LongKeyFlag_1;

#define		KEY_2_IO	 PA.4//定义按键的脚位

bit KeyFlag_2;  			//启动按键检测
bit JugeKeyStateFlag_2;		//消抖结束-->判断按键状态
uint16_t RemoveKey1ms_2;		//按键消抖检测时间
bit LongKeyProFlag_2;		//防止重复检测
uint16_t KeyCount1ms_2;		//按键计时
	
bit ShortKeyFlag_2;
bit LongKeyFlag_2;

